# =============================================================================
# Environment variables for fashbiz (Ree)
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the real values.
# Get the real values from the client or from the Vercel project dashboard:
#   Vercel → Project → Settings → Environment Variables
# `.env.local` is gitignored — never commit real secrets.
# Restart `npm run dev` after editing.
# =============================================================================

# --- App / URLs --------------------------------------------------------------
APP_NAME=Ree
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_FRONTEND_LIVE_URL=https://re-e.dk

# --- Database (required for login) -------------------------------------------
MONGODB_URI=

# --- Auth (NextAuth — required for login) ------------------------------------
AUTH_SECRET=
REFERRAL_SECRET_KEY=

# --- Stripe (required for subscription/payment pages) ------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Cloudinary (image uploads) ----------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- OpenAI ------------------------------------------------------------------
OPENAI_API_KEY=

# --- Email / SMTP ------------------------------------------------------------
EMAIL_USER=
EMAIL_PASS=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=

# --- Shopify integration -----------------------------------------------------
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_SECRET=
SHOPIFY_FACEBOOK_PUBLICATION_ID=

# --- Wix integration ---------------------------------------------------------
WIX_CLIENT_ID=
WIX_SITE_ID=
WIX_API_KEY=

# --- Meta / Instagram catalog ------------------------------------------------
META_CATALOG_ID=
META_PAGE_ID=
META_IG_ACCESS_TOKEN=

# --- Misc --------------------------------------------------------------------
TEST_STORE_USER_ID=
